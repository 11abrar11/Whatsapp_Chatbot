# ============================================================
# WhatsApp AI Chatbot — Environment Variables
# Copy this file to config/.env and fill in your values
# ============================================================

# === LLM (Groq — Free Tier) ===
# Get your key at: https://console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# === Embeddings (Google Gemini — Free Tier) ===
# Get your key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_EMBEDDING_MODEL=text-embedding-004

# === Qdrant (Vector Database — Local Docker) ===
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=pp5_knowledge

# === Baileys (WhatsApp via WhatsApp Web) ===
# URL of the Baileys Node.js service (runs alongside this backend)
BAILEYS_SERVICE_URL=http://localhost:3001

# === Google Sheets (Lead Storage) ===
# Create a service account at: https://console.cloud.google.com
# See docs/google_sheet_setup.md for detailed instructions
GOOGLE_SHEET_ID=your_google_sheet_id_here
GOOGLE_SERVICE_ACCOUNT_JSON=/app/config/service_account.json

# === Gmail SMTP (Escalation Emails) ===
# Use an App Password: https://myaccount.google.com/apppasswords
GMAIL_SENDER=your_email@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password
ESCALATION_RECIPIENT=team@pp5mediasolutions.com

# === Application ===
BACKEND_PORT=8000
LOG_LEVEL=INFO
